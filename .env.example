# ── Google (Gmail + Google Calendar) ─────────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/
# Download the JSON and paste the client_id and client_secret here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated Gmail addresses to sync
GMAIL_ACCOUNTS=you@gmail.com

# ── Microsoft (Outlook) ──────────────────────────────────────────────────────
# Register an app at https://portal.azure.com/ → Azure AD → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# Comma-separated Outlook addresses to sync
OUTLOOK_ACCOUNTS=you@outlook.com,you@hotmail.com

# ── Roundcube / IMAP ─────────────────────────────────────────────────────────
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=
IMAP_USE_SSL=true

# ── SMTP (outbound for IMAP accounts) ────────────────────────────────────────
# Defaults to IMAP_HOST/USERNAME/PASSWORD if left empty.
# SMTP_SSL=false uses STARTTLS (port 587); set true for implicit SSL (port 465).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SSL=false

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ── App ──────────────────────────────────────────────────────────────────────
# How often to sync emails (seconds)
SYNC_INTERVAL_SECONDS=300
# Port FastAPI listens on (accessible from local network)
APP_PORT=8000
# Secret key for session signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-generate-a-random-string
